{
  "manifest_version": 3,
  "name": "GitHub PR Links New Tab",
  "version": "1.0.0",
  "description": "GitHub Pull Request ページの全てのリンクを新しいタブで開くようにします",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["https://github.com/*/pull/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
